# FLUX environment variables example
# Copy this file to .env and fill in your API keys.

# Groq (LLM) API key
GROQ_API_KEY=

# Google API key (enable YouTube Data API v3)
GOOGLE_API_KEY=

# The Movie Database (TMDB) API key
TMDB_API_KEY=

# Optional: a local dev flag
FLUX_ENV=development
